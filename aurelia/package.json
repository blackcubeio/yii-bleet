        },
        "quill": {
            "optional": false
        },
        "socket.io-client": {
            "optional": true
        }
    },
    "scripts": {
        "clean": "rimraf ./dist",
        "build": "rollup -c",
        "prebuild": "npm run clean && tsc --emitDeclarationOnly",
        "build:watch": "rollup -cw"
